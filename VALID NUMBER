#include <stdbool.h>
#include <ctype.h>

bool isNumber(char* s) {
    bool seenDigit = false;
    bool seenDot = false;
    bool seenE = false;

    for (int i = 0; s[i] != '\0'; i++) {
        if (isdigit(s[i])) {
            seenDigit = true;
        } else if (s[i] == '+' || s[i] == '-') {
            if (i > 0 && s[i - 1] != 'e' && s[i - 1] != 'E') return false;
        } else if (s[i] == 'e' || s[i] == 'E') {
            if (seenE || !seenDigit) return false;
            seenE = true;
            seenDigit = false; 
        } else if (s[i] == '.') {
            if (seenDot || seenE) return false;
            seenDot = true;
        } else {
            return false;
        }
    }

    return seenDigit;
}
