#include <stdlib.h>

struct ListNode* partition(struct ListNode* head, int x) {
    struct ListNode lessHead = {0, NULL};
    struct ListNode moreHead = {0, NULL};
    struct ListNode *less = &lessHead;
    struct ListNode *more = &moreHead;

    while (head) {
        if (head->val < x) {
            less->next = head;
            less = less->next;
        } else {
            more->next = head;
            more = more->next;
        }
        head = head->next;
    }

    more->next = NULL;
    less->next = moreHead.next;

    return lessHead.next;
}

