#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* getPermutation(int n, int k) {
    int* factorial = (int*)malloc(n * sizeof(int));
    int* nums = (int*)malloc(n * sizeof(int));
    char* result = (char*)malloc((n + 1) * sizeof(char));
    
    factorial[0] = 1;
    for (int i = 1; i < n; i++) {
        factorial[i] = factorial[i - 1] * i;
        nums[i - 1] = i;
    }
    nums[n - 1] = n;

    k--; // Convert to 0-indexed
    
    for (int i = 0; i < n; i++) {
        int index = k / factorial[n - 1 - i];
        result[i] = nums[index] + '0';
        
        // Shift remaining numbers to fill the gap
        for (int j = index; j < n - 1; j++) {
            nums[j] = nums[j + 1];
        }
        
        k %= factorial[n - 1 - i];
    }
    
    result[n] = '\0';
    free(factorial);
    free(nums);
    return result;
}

