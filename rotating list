struct ListNode* rotateRight(struct ListNode* head, int k) {
    if (!head || !head->next || k == 0) return head;

    // 1. Find the length and the tail node
    struct ListNode* tail = head;
    int length = 1;
    while (tail->next) {
        tail = tail->next;
        length++;
    }

    // 2. Adjust k (if k > length, we only need k % length)
    k = k % length;
    if (k == 0) return head;

    // 3. Connect tail to head to make it circular
    tail->next = head;

    // 4. Find the new tail: (length - k) nodes from the start
    int stepsToNewTail = length - k;
    struct ListNode* newTail = tail;
    while (stepsToNewTail--) {
        newTail = newTail->next;
    }

    // 5. Set the new head and break the circle
    struct ListNode* newHead = newTail->next;
    newTail->next = NULL;

    return newHead;
}
