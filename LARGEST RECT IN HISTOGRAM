#include <stdio.h>
#include <stdlib.h>

// Using an ifndef guard to prevent redefinition errors 
#ifndef MAX
#define MAX(a, b) ((a) > (b) ? (a) : (b))
#endif

int largestRectangleArea(int* heights, int heightsSize) {
    if (heightsSize == 0) return 0;

    // Stack to store indices of the histogram bars
    int* stack = (int*)malloc((heightsSize + 1) * sizeof(int));
    int top = -1;
    int maxArea = 0;

    for (int i = 0; i <= heightsSize; i++) {
        // Use a dummy bar of height 0 at the end to flush the stack
        int currentHeight = (i == heightsSize) ? 0 : heights[i];

        // While the current bar is shorter than the bar at the stack top
        while (top != -1 && heights[stack[top]] >= currentHeight) {
            int h = heights[stack[top--]];
            // Width is current index 'i' if stack is empty, 
            // otherwise it's the distance between current index and new stack top
            int w = (top == -1) ? i : (i - stack[top] - 1);
            int area = h * w;
            maxArea = MAX(maxArea, area);
        }
        // Push the current index onto the stack
        stack[++top] = i;
    }

    free(stack);
    return maxArea;
}
