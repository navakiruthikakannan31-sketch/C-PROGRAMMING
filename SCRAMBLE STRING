#include <stdbool.h>
#include <string.h>

signed char memo[31][31][31];

bool solve(char* s1, char* s2, int i, int j, int len) {
    if (memo[i][j][len] != -1) return memo[i][j][len];

    bool match = true;
    for (int k = 0; k < len; k++) {
        if (s1[i + k] != s2[j + k]) {
            match = false;
            break;
        }
    }
    if (match) return memo[i][j][len] = 1;

    int count[26] = {0};
    for (int k = 0; k < len; k++) {
        count[s1[i + k] - 'a']++;
        count[s2[j + k] - 'a']--;
    }
    for (int k = 0; k < 26; k++) {
        if (count[k] != 0) return memo[i][j][len] = 0;
    }

    for (int k = 1; k < len; k++) {
        if ((solve(s1, s2, i, j, k) && solve(s1, s2, i + k, j + k, len - k)) ||
            (solve(s1, s2, i, j + len - k, k) && solve(s1, s2, i + k, j, len - k))) {
            return memo[i][j][len] = 1;
        }
    }

    return memo[i][j][len] = 0;
}

bool isScramble(char* s1, char* s2) {
    int n = strlen(s1);
    memset(memo, -1, sizeof(memo));
    return solve(s1, s2, 0, 0, n);
}
