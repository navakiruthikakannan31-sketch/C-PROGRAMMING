#include <string.h>
#include <stdlib.h>
#include <limits.h>

char* minWindow(char* s, char* t) {
    int m = strlen(s);
    int n = strlen(t);
    if (m < n) return "";

    int map[128] = {0};
    for (int i = 0; i < n; i++) map[t[i]]++;

    int start = 0, end = 0, minLen = INT_MAX, head = 0;
    int counter = n;

    while (end < m) {
        if (map[s[end]] > 0) counter--;
        map[s[end]]--;
        end++;

        while (counter == 0) {
            if (end - start < minLen) {
                minLen = end - start;
                head = start;
            }
            map[s[start]]++;
            if (map[s[start]] > 0) counter++;
            start++;
        }
    }

    if (minLen == INT_MAX) return "";

    char* result = (char*)malloc((minLen + 1) * sizeof(char));
    strncpy(result, s + head, minLen);
    result[minLen] = '\0';
    return result;
}
