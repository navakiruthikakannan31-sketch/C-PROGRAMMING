#include <stdio.h>
#include <stdlib.h>

#define MAXN 100005
#define LOGN 20

typedef struct Node {
    int to;
    struct Node* next;
} Node;

Node* adj[MAXN];
int parent[MAXN][LOGN];
long long sum_guards[MAXN];
int guards[MAXN];
int depth[MAXN];

void add_edge(int u, int v) {
    Node* newNode = (Node*)malloc(sizeof(Node));
    newNode->to = v;
    newNode->next = adj[u];
    adj[u] = newNode;
}

void dfs(int u, int p, int d, long long current_sum) {
    depth[u] = d;
    parent[u][0] = p;
    sum_guards[u] = current_sum + guards[u];
    
    for (int i = 1; i < LOGN; i++) {
        parent[u][i] = parent[parent[u][i - 1]][i - 1];
    }

    Node* curr = adj[u];
    while (curr) {
        if (curr->to != p) {
            dfs(curr->to, u, d + 1, sum_guards[u]);
        }
        curr = curr->next;
    }
}

int solve_query(int u, int k) {
    // If guards in the starting city can stop everyone
    if (guards[u] >= k) return u;

    int curr = u;
    // We want to find the highest ancestor 'v' such that 
    // total guards from u to v (inclusive) < k.
    // The rebels will stop at the city immediately after 'v' on the path to 1.
    for (int i = LOGN - 1; i >= 0; i--) {
        int ancestor = parent[curr][i];
        if (ancestor != 0) {
            // Guards encountered = sum_guards[u] - sum_guards[parent[ancestor][0]]
            // But it's easier to check if remaining rebels > 0
            long long guards_on_path = sum_guards[u] - sum_guards[parent[ancestor][0]];
            if (guards_on_path < k) {
                curr = ancestor;
            }
        }
    }
    
    // Rebels passed 'curr', they try to move to parent[curr][0]
    return (parent[curr][0] == 0) ? curr : parent[curr][0];
}

void solve() {
    int n;
    if (scanf("%d", &n) != 1) return;

    for (int i = 1; i <= n; i++) {
        adj[i] = NULL;
        for (int j = 0; j < LOGN; j++) parent[i][j] = 0;
    }

    for (int i = 0; i < n - 1; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        add_edge(u, v);
        add_edge(v, u);
    }

    for (int i = 1; i <= n; i++) scanf("%d", &guards[i]);

    dfs(1, 0, 0, 0);

    int q;
    scanf("%d", &q);
    while (q--) {
        int u, k;
        scanf("%d %d", &u, &k);
        printf("%d\n", solve_query(u, k));
    }

    // Clean up memory
    for (int i = 1; i <= n; i++) {
        Node* curr = adj[i];
        while (curr) {
            Node* temp = curr;
            curr = curr->next;
            free(temp);
        }
    }
}

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
